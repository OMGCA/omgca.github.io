---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import OnlineProfile from '../components/OnlineProfile.astro';
import OfflineProfile from '../components/OfflineProfile.astro';
import OnlineContent from '../components/OnlineContent.astro';
import OfflineContent from '../components/OfflineContent.astro';
import BlogCard from '../components/BlogCard.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPost = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];
---

<BaseLayout title="Sebastian — Home">
  <!-- Online persona -->
  <div class="mode-section mode-online">
    <div class="profile-section">
      <OnlineProfile />
    </div>
    <div class="content-section">
      {latestPost && (
        <section class="latest-blog">
          <div class="section-header">
            <h2>Latest Blog</h2>
            <a href="/blog" class="section-link">All posts &rarr;</a>
          </div>
          <BlogCard post={latestPost} />
        </section>
      )}

      <OnlineContent />
    </div>
  </div>

  <!-- Offline persona -->
  <div class="mode-section mode-offline">
    <div class="profile-section">
      <OfflineProfile />
    </div>
    <div class="content-section">
      <OfflineContent />
    </div>
  </div>
</BaseLayout>

<style>
  .latest-blog {
    margin-bottom: 2.5rem;
  }

  .latest-blog .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .latest-blog .section-header h2 {
    margin-bottom: 0;
  }

  .section-link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .section-link:hover {
    color: var(--color-accent);
  }
</style>
