---
// Offline mode profile — professional persona
---

<div class="profile">
  <div class="profile-avatar">
    <img
      src="https://media.licdn.com/dms/image/v2/C5603AQGoqE9JRtrWcA/profile-displayphoto-shrink_800_800/profile-displayphoto-shrink_800_800/0/1638113018937?e=1783555200&v=beta&t=8OP04GwNU557FQqg8hWgJvKYPKrQCd8SyoN_4z_Kkm4"
      alt="Tian Xia"
      class="avatar-img"
      width="96"
      height="96"
    />
  </div>
  <div class="profile-info">
    <h1 class="profile-name">
      Tian <span class="profile-nickname">'Sebastian'</span> Xia
    </h1>
    <p class="profile-title">Mobile App Software Engineer</p>
    <p class="profile-bio">
      Insta360 Software Engineer, building the HarmonyOS application and the Android cloud storage service client.
    </p>
    <p class="profile-edu">
      MSc (Res) &amp; BEng, University of York (2015–2020)
    </p>
    <div class="profile-links">
      <a
        href="https://www.linkedin.com/in/t-seb-xia/"
        class="profile-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        <span>LinkedIn</span>
      </a>
      <a
        href="mailto:t.seb.xia@gmail.com"
        class="profile-link"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 4-10 8L2 4"/>
        </svg>
        <span>Email</span>
      </a>
    </div>
  </div>
</div>

<style>
  .profile {
    display: flex;
    gap: 1.75rem;
    align-items: flex-start;
    margin-bottom: 3rem;
  }

  .profile-avatar {
    flex-shrink: 0;
  }

  .avatar-img {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 2px solid var(--color-border);
    object-fit: cover;
    display: block;
    transition: var(--transition-colors);
  }

  .avatar-placeholder {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background-color: var(--color-surface-elevated);
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    transition: var(--transition-colors);
  }

  .profile-info {
    min-width: 0;
  }

  .profile-name {
    margin-bottom: 0.25rem;
  }

  .profile-nickname {
    color: var(--color-accent);
  }

  .profile-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    color: var(--color-accent);
    margin: 0 0 0.75rem;
  }

  .profile-bio {
    margin-bottom: 0.5rem;
    max-width: 36rem;
    font-size: 0.9375rem;
  }

  .profile-edu {
    margin-bottom: 1rem;
    max-width: 36rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .profile-links {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .profile-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .profile-link:hover {
    color: var(--color-accent);
    background-color: var(--color-accent-muted);
  }

  @media (max-width: 640px) {
    .profile {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .profile-links {
      justify-content: center;
    }
  }
</style>
