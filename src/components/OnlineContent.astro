---
// Online mode main content — photography
import PhotographyGrid from './PhotographyGrid.astro';
---

<section class="online-content">
  <div class="section-header">
    <h2>Photography</h2>
    <p class="section-sub">Selected shots</p>
  </div>
  <PhotographyGrid />
</section>

<style>
  .online-content {
    margin-top: 0.5rem;
  }

  .section-header {
    margin-bottom: 1.25rem;
  }

  .section-header h2 {
    margin-bottom: 0.125rem;
  }

  .section-sub {
    font-size: 0.875rem;
    margin: 0;
  }
</style>
