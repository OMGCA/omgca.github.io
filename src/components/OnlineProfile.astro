---
// Online mode profile — casual / gaming persona
---

<div class="profile">
  <div class="profile-avatar">
    <img
      src="https://avatars.githubusercontent.com/u/41295316"
      alt="OMGCA"
      class="avatar-img"
      width="96"
      height="96"
    />
  </div>
  <div class="profile-info">
    <h1 class="profile-name">
      <span class="profile-nickname">OMGCA</span>
    </h1>
    <p class="profile-bio">
      A sorry collection of organic cells
    </p>
    <div class="profile-links">
      <a
        href="https://steamcommunity.com/id/OMGCA/"
        class="profile-link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Steam profile"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zM8.5 9.2 6 16l3.5 2.5 1-2 2 .5.5-2-2-.5.5-2.5-3-2.8zm5.5 0 1 2.5-2 .5.5 2 2 .5 1 2L20 16l-2.5-6.8L14 9.2z"/>
        </svg>
        <span>Steam</span>
      </a>
      <a
        href="https://space.bilibili.com/6514851"
        class="profile-link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Bilibili space"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
          <polyline points="10 9 15 12 10 15 10 9" />
        </svg>
        <span>Bilibili</span>
      </a>
    </div>
  </div>
</div>

<style>
  .profile {
    display: flex;
    gap: 1.75rem;
    align-items: flex-start;
    margin-bottom: 3rem;
  }

  .profile-avatar {
    flex-shrink: 0;
  }

  .avatar-img {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 2px solid var(--color-border);
    object-fit: cover;
    display: block;
    transition: var(--transition-colors);
  }

  .avatar-placeholder {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background-color: var(--color-surface-elevated);
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    transition: var(--transition-colors);
  }

  .profile-info {
    min-width: 0;
  }

  .profile-name {
    margin-bottom: 0.375rem;
  }

  .profile-nickname {
    color: var(--color-accent);
  }

  .profile-bio {
    margin-bottom: 1rem;
    max-width: 36rem;
    font-size: 0.9375rem;
  }

  .profile-links {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .profile-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .profile-link:hover {
    color: var(--color-accent);
    background-color: var(--color-accent-muted);
  }

  @media (max-width: 640px) {
    .profile {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .profile-links {
      justify-content: center;
    }
  }
</style>
