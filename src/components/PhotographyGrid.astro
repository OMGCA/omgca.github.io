---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Glob-import all photos from src/assets/photos/
// Case-insensitive patterns: camera files use uppercase .JPG; Linux CI is case-sensitive
const photoFiles = import.meta.glob(
  '../assets/photos/*.{jpg,jpeg,JPG,JPEG,png,PNG,webp,WEBP,avif,AVIF}'
);

// Resolve all imports to get ImageMetadata objects
const resolved = await Promise.all(Object.values(photoFiles).map(fn => fn()));
let photoMetadata = resolved.map(r => (r as { default: ImageMetadata }).default);

// Server-side shuffle for initial page load (client script re-shuffles DOM)
photoMetadata = photoMetadata.sort(() => Math.random() - 0.5);
const photoCount = photoMetadata.length;

// Generate optimized thumbnails at build time
// Grid layout: 3-col desktop (~290px per card), 2-col tablet (~350px), 1-col mobile
// width: 400 covers 1x displays; srcset handles HiDPI and larger breakpoints
// fit: 'cover' crops to 4:3 aspect ratio matching the CSS object-fit: cover
const optimizedPhotos = photoCount > 0
  ? await Promise.all(photoMetadata.map(img =>
      getImage({
        src: img,
        width: 400,
        widths: [300, 400, 600, 800],
        height: 300,
        format: 'webp',
        fit: 'cover',
      })
    ))
  : [];
---

{photoCount === 0 ? (
  <div class="photo-empty surface">
    <p>No photos yet. Add images to <code>src/assets/photos/</code>.</p>
  </div>
) : (
  <div class="photo-grid" id="photo-grid">
    {optimizedPhotos.map(img => (
      <div class="photo-card surface">
        <img
          src={img.src}
          srcset={img.srcSet.attribute}
          sizes="(max-width: 480px) 100vw, (max-width: 768px) 50vw, 33vw"
          alt=""
          loading="lazy"
          decoding="async"
          class="photo-img"
          width={img.attributes.width}
          height={img.attributes.height}
          onload="this.style.opacity='1'"
        />
      </div>
    ))}
  </div>
)}

<style>
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .photo-card {
    overflow: hidden;
    aspect-ratio: 4 / 3;
    padding: 0;
    cursor: pointer;
    transition: box-shadow 0.3s ease;
  }

  .photo-card:hover {
    box-shadow: 0 4px 24px var(--color-shadow);
  }

  .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .photo-empty {
    padding: 2rem;
    text-align: center;
  }

  .photo-empty p {
    margin: 0;
    font-size: 0.9375rem;
  }

  @media (max-width: 768px) {
    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .photo-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const grid = document.getElementById('photo-grid');
  if (grid) {
    const cards = Array.from(grid.children);
    for (let i = cards.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      grid.appendChild(cards[j]);
    }
  }
</script>
