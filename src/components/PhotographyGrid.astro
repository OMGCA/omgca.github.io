---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Glob-import all photos from src/assets/photos/
// Case-insensitive patterns: camera files use uppercase .JPG; Linux CI is case-sensitive
const photoFiles = import.meta.glob(
  '../assets/photos/*.{jpg,jpeg,JPG,JPEG,png,PNG,webp,WEBP,avif,AVIF}'
);

// Resolve all imports to get ImageMetadata objects
const resolved = await Promise.all(Object.values(photoFiles).map(fn => fn()));
let photoMetadata = resolved.map(r => (r as { default: ImageMetadata }).default);

// Server-side shuffle + cap at 18 for initial page load (client script re-shuffles DOM)
photoMetadata = photoMetadata.sort(() => Math.random() - 0.5).slice(0, 18);
const photoCount = photoMetadata.length;

// Generate optimized thumbnails at build time
// Grid layout: 3-col desktop (~290px per card), 2-col tablet (~350px), 1-col mobile
// width: 400 covers 1x displays; srcset handles HiDPI and larger breakpoints
// fit: 'cover' crops to 4:3 aspect ratio matching the CSS object-fit: cover
const optimizedPhotos = photoCount > 0
  ? await Promise.all(photoMetadata.map(img =>
      getImage({
        src: img,
        width: 400,
        widths: [300, 400, 600, 800],
        height: 300,
        format: 'webp',
        fit: 'cover',
      })
    ))
  : [];
---

{photoCount === 0 ? (
  <div class="photo-empty surface">
    <p>No photos yet. Add images to <code>src/assets/photos/</code>.</p>
  </div>
) : (
  <>
    <div class="photo-grid" id="photo-grid">
      {optimizedPhotos.map((img, i) => (
        <div class="photo-card surface">
          <img
            src={img.src}
            srcset={img.srcSet.attribute}
            sizes="(max-width: 480px) 100vw, (max-width: 768px) 50vw, 33vw"
            alt=""
            loading="lazy"
            decoding="async"
            class="photo-img"
            width={img.attributes.width}
            height={img.attributes.height}
            onload="this.style.opacity='1'"
            data-full-src={photoMetadata[i]?.src}
          />
        </div>
      ))}
    </div>

    <div class="lightbox-overlay" id="lightbox-overlay">
      <button class="lightbox-close" id="lightbox-close" aria-label="Close">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <div class="lightbox-img-wrap" id="lightbox-img-wrap">
        <img class="lightbox-img" id="lightbox-img" alt="" />
      </div>
    </div>
  </>
)}

<style>
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .photo-card {
    overflow: hidden;
    aspect-ratio: 4 / 3;
    padding: 0;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .photo-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px var(--color-shadow);
  }

  .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .photo-empty {
    padding: 2rem;
    text-align: center;
  }

  .photo-empty p {
    margin: 0;
    font-size: 0.9375rem;
  }

  /* Lightbox */
  .lightbox-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.5);
    align-items: center;
    justify-content: center;
    transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .lightbox-overlay.open {
    display: flex;
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 1001;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #fff;
    transition: background 0.2s ease;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .lightbox-img-wrap {
    max-width: min(82vw, 900px);
    max-height: min(82vh, 900px);
    border-radius: 8px;
    background: #2a2a2e;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.08), 0 24px 80px rgba(0, 0, 0, 0.55);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .lightbox-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    border-radius: 8px;
  }

  @media (max-width: 768px) {
    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .photo-grid {
      grid-template-columns: 1fr;
    }

    .lightbox-img-wrap {
      max-width: min(92vw, 600px);
      max-height: min(85vh, 600px);
    }
  }
</style>

<script>
  const grid = document.getElementById('photo-grid');
  if (grid) {
    const cards = Array.from(grid.children);
    for (let i = cards.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      grid.appendChild(cards[j]);
    }
  }

  // Lightbox with FLIP animation
  const overlay = document.getElementById('lightbox-overlay');
  const lightboxWrap = document.getElementById('lightbox-img-wrap');
  const lightboxImg = document.getElementById('lightbox-img');
  const closeBtn = document.getElementById('lightbox-close');
  let activeThumb = null;

  function openLightbox(src, thumbImg) {
    const thumbRect = thumbImg.getBoundingClientRect();
    const vpW = window.innerWidth;
    const vpH = window.innerHeight;
    const vpCX = vpW / 2;
    const vpCY = vpH / 2;

    const thumbCX = thumbRect.left + thumbRect.width / 2;
    const thumbCY = thumbRect.top + thumbRect.height / 2;

    // Approximate final rendered size within max constraints
    const finalMaxW = Math.min(vpW * 0.82, 900);
    const finalMaxH = Math.min(vpH * 0.82, 900);
    const sx = Math.min(thumbRect.width / finalMaxW, 1);
    const sy = Math.min(thumbRect.height / finalMaxH, 1);

    activeThumb = thumbImg;

    // Clear stale previous image then load new one progressively
    lightboxImg.src = '';
    requestAnimationFrame(() => {
      lightboxImg.src = src;
    });

    // Snap wrap to thumbnail position (no transition)
    lightboxWrap.style.transition = 'none';
    lightboxWrap.style.transform = `translate(${thumbCX - vpCX}px, ${thumbCY - vpCY}px) scale(${sx}, ${sy})`;

    overlay.classList.add('open');
    overlay.style.opacity = '0';

    // Force reflow so the initial position is painted
    lightboxWrap.offsetHeight;

    // Animate wrap to center
    lightboxWrap.style.transition = 'transform 0.35s cubic-bezier(0.4, 0, 0.2, 1)';
    lightboxWrap.style.transform = 'translate(0, 0) scale(1, 1)';
    overlay.style.opacity = '1';

    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    if (activeThumb) {
      const thumbRect = activeThumb.getBoundingClientRect();
      const inView = thumbRect.top < window.innerHeight && thumbRect.bottom > 0 &&
                     thumbRect.left < window.innerWidth && thumbRect.right > 0;

      if (inView) {
        const vpW = window.innerWidth;
        const vpH = window.innerHeight;
        const vpCX = vpW / 2;
        const vpCY = vpH / 2;
        const thumbCX = thumbRect.left + thumbRect.width / 2;
        const thumbCY = thumbRect.top + thumbRect.height / 2;
        const finalMaxW = Math.min(vpW * 0.82, 900);
        const finalMaxH = Math.min(vpH * 0.82, 900);
        const sx = Math.min(thumbRect.width / finalMaxW, 1);
        const sy = Math.min(thumbRect.height / finalMaxH, 1);

        lightboxWrap.style.transform = `translate(${thumbCX - vpCX}px, ${thumbCY - vpCY}px) scale(${sx}, ${sy})`;
        overlay.style.opacity = '0';

        setTimeout(() => finishClose(), 350);
        return;
      }
    }
    finishClose();
  }

  function finishClose() {
    overlay.classList.remove('open');
    overlay.style.opacity = '';
    lightboxWrap.style.transform = '';
    lightboxWrap.style.transition = '';
    activeThumb = null;
    document.body.style.overflow = '';
  }

  const photoGrid = document.getElementById('photo-grid');
  if (photoGrid) {
    photoGrid.addEventListener('click', (e) => {
      const img = e.target.closest('.photo-card')?.querySelector('img');
      if (img) {
        const fullSrc = img.getAttribute('data-full-src');
        if (fullSrc) openLightbox(fullSrc, img);
      }
    });
  }

  closeBtn?.addEventListener('click', closeLightbox);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay?.classList.contains('open')) closeLightbox();
  });
</script>
