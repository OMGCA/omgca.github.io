---
import { readdirSync } from 'node:fs';
import { extname, join } from 'node:path';

const photosDir = join(process.cwd(), 'public', 'photos');
const imageExtensions = new Set(['.jpg', '.jpeg', '.png', '.webp', '.avif']);

let photoFiles: string[] = [];
try {
  photoFiles = readdirSync(photosDir)
    .filter(f => imageExtensions.has(extname(f).toLowerCase()))
    .sort(() => Math.random() - 0.5);
} catch {
  photoFiles = [];
}

const photoCount = photoFiles.length;
---

{photoCount === 0 ? (
  <div class="photo-empty surface">
    <p>No photos yet. Add images to <code>public/photos/</code>.</p>
  </div>
) : (
  <div class="photo-grid" id="photo-grid">
    {photoFiles.map(file => (
      <div class="photo-card surface">
        <img
          src={`/photos/${file}`}
          alt=""
          loading="lazy"
          decoding="async"
          class="photo-img"
          onload="this.style.opacity='1'"
        />
      </div>
    ))}
  </div>
)}

<style>
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .photo-card {
    overflow: hidden;
    aspect-ratio: 4 / 3;
    padding: 0;
    cursor: pointer;
    transition: box-shadow 0.3s ease;
  }

  .photo-card:hover {
    box-shadow: 0 4px 24px var(--color-shadow);
  }

  .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .photo-empty {
    padding: 2rem;
    text-align: center;
  }

  .photo-empty p {
    margin: 0;
    font-size: 0.9375rem;
  }

  @media (max-width: 768px) {
    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .photo-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const grid = document.getElementById('photo-grid');
  if (grid) {
    const cards = Array.from(grid.children);
    for (let i = cards.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      grid.appendChild(cards[j]);
    }
  }
</script>
