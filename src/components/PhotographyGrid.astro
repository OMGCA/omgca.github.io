---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Glob-import all photos from src/assets/photos/
// Case-insensitive patterns: camera files use uppercase .JPG; Linux CI is case-sensitive
const photoFiles = import.meta.glob(
  '../assets/photos/*.{jpg,jpeg,JPG,JPEG,png,PNG,webp,WEBP,avif,AVIF}'
);

// Resolve all imports to get ImageMetadata objects
const resolved = await Promise.all(Object.values(photoFiles).map(fn => fn()));
let photoMetadata = resolved.map(r => (r as { default: ImageMetadata }).default);

// Server-side shuffle + cap at 18 for initial page load (client script re-shuffles DOM)
photoMetadata = photoMetadata.sort(() => Math.random() - 0.5).slice(0, 18);
const photoCount = photoMetadata.length;

// Generate optimized thumbnails at build time
// Grid layout: 3-col desktop (~290px per card), 2-col tablet (~350px), 1-col mobile
// width: 400 covers 1x displays; srcset handles HiDPI and larger breakpoints
// fit: 'cover' crops to 4:3 aspect ratio matching the CSS object-fit: cover
const optimizedPhotos = photoCount > 0
  ? await Promise.all(photoMetadata.map(img =>
      getImage({
        src: img,
        width: 400,
        widths: [300, 400, 600, 800],
        height: 300,
        format: 'webp',
        fit: 'cover',
      })
    ))
  : [];
---

{photoCount === 0 ? (
  <div class="photo-empty surface">
    <p>No photos yet. Add images to <code>src/assets/photos/</code>.</p>
  </div>
) : (
  <>
    <div class="photo-grid" id="photo-grid">
      {optimizedPhotos.map((img, i) => (
        <div class="photo-card surface">
          <img
            src={img.src}
            srcset={img.srcSet.attribute}
            sizes="(max-width: 480px) 100vw, (max-width: 768px) 50vw, 33vw"
            alt=""
            loading="lazy"
            decoding="async"
            class="photo-img"
            width={img.attributes.width}
            height={img.attributes.height}
            onload="this.style.opacity='1'"
            data-full-src={photoMetadata[i]?.src}
          />
        </div>
      ))}
    </div>

    <div class="lightbox-overlay" id="lightbox-overlay">
      <button class="lightbox-close" id="lightbox-close" aria-label="Close">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <img class="lightbox-img" id="lightbox-img" alt="" />
    </div>
  </>
)}

<style>
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .photo-card {
    overflow: hidden;
    aspect-ratio: 4 / 3;
    padding: 0;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .photo-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px var(--color-shadow);
  }

  .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .photo-empty {
    padding: 2rem;
    text-align: center;
  }

  .photo-empty p {
    margin: 0;
    font-size: 0.9375rem;
  }

  /* Lightbox */
  .lightbox-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.85);
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .lightbox-overlay.open {
    display: flex;
    opacity: 1;
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 1001;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #fff;
    transition: background 0.2s ease;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .lightbox-img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 16px 64px rgba(0, 0, 0, 0.5);
    transform: scale(0.9);
    transition: transform 0.3s ease;
  }

  .lightbox-overlay.open .lightbox-img {
    transform: scale(1);
  }

  @media (max-width: 768px) {
    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .photo-grid {
      grid-template-columns: 1fr;
    }

    .lightbox-img {
      max-width: 95vw;
      max-height: 85vh;
    }
  }
</style>

<script>
  const grid = document.getElementById('photo-grid');
  if (grid) {
    const cards = Array.from(grid.children);
    for (let i = cards.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      grid.appendChild(cards[j]);
    }
  }

  // Lightbox
  const overlay = document.getElementById('lightbox-overlay');
  const lightboxImg = document.getElementById('lightbox-img');
  const closeBtn = document.getElementById('lightbox-close');

  function openLightbox(src) {
    lightboxImg.src = src;
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  // Delegate click on grid to handle all photo cards
  const photoGrid = document.getElementById('photo-grid');
  if (photoGrid) {
    photoGrid.addEventListener('click', (e) => {
      const img = e.target.closest('.photo-card')?.querySelector('img');
      if (img) {
        const fullSrc = img.getAttribute('data-full-src');
        if (fullSrc) openLightbox(fullSrc);
      }
    });
  }

  closeBtn?.addEventListener('click', closeLightbox);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay?.classList.contains('open')) closeLightbox();
  });
</script>
